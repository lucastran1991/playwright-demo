{
  "project": "playwright-demo",
  "backend": {
    "name": "api",
    "cwd": "./backend",
    "command": "go run ./cmd/server",
    "port": 8889,
    "url": "http://localhost:8889",
    "env_file": "./backend/.env",
    "env": {
      "BLUEPRINT_DIR": "./blueprint/Node & Edge",
      "MODEL_DIR": "./blueprint"
    }
  },
  "frontend": {
    "name": "web",
    "cwd": "./frontend",
    "command": "pnpm dev",
    "port": 8089,
    "url": "http://localhost:8089",
    "env_file": "./frontend/.env.local"
  },
  "database": {
    "type": "postgresql",
    "name": "app_dev",
    "host": "localhost",
    "port": 5432
  },
  "api": {
    "base_url": "http://localhost:8889",
    "health": "/health",
    "auth": {
      "register": "/api/auth/register",
      "login": "/api/auth/login"
    },
    "blueprints": {
      "ingest": "/api/blueprints/ingest",
      "types": "/api/blueprints/types",
      "nodes": "/api/blueprints/nodes"
    },
    "models": {
      "ingest": "/api/models/ingest",
      "capacity_nodes": "/api/models/capacity-nodes"
    },
    "trace": {
      "dependencies": "/api/trace/dependencies/:nodeId",
      "impacts": "/api/trace/impacts/:nodeId"
    }
  }
}
